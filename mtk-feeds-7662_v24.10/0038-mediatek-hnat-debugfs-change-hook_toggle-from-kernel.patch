From 6d6966c3e33d5754881f5587ff89e800197438b3 Mon Sep 17 00:00:00 2001
From: chasey-dev <ellenyoung0912@gmail.com>
Date: Tue, 25 Nov 2025 18:46:22 +0800
Subject: [PATCH 38/64] mediatek: hnat: debugfs: change hook_toggle from kernel
 logging to stdout - since hook_toggle check is more frequently needed in some
 scripts checking hnat status, we suppress kernel logging of it and change it
 to stdout using `seq_printf()`

Signed-off-by: chasey-dev <ellenyoung0912@gmail.com>
---
 ...at-debugfs-change-hook-toggle-read-to-stdout.patch | 11 +++++++++++
 1 file changed, 11 insertions(+)
 create mode 100644 target/linux/mediatek/patches-6.6/999-2799-9-mtk-hnat-debugfs-change-hook-toggle-read-to-stdout.patch

diff --git a/target/linux/mediatek/patches-6.6/999-2799-9-mtk-hnat-debugfs-change-hook-toggle-read-to-stdout.patch b/target/linux/mediatek/patches-6.6/999-2799-9-mtk-hnat-debugfs-change-hook-toggle-read-to-stdout.patch
new file mode 100644
index 0000000000..b674f4588a
--- /dev/null
+++ b/target/linux/mediatek/patches-6.6/999-2799-9-mtk-hnat-debugfs-change-hook-toggle-read-to-stdout.patch
@@ -0,0 +1,11 @@
+--- a/drivers/net/ethernet/mediatek/mtk_hnat/hnat_debugfs.c
++++ b/drivers/net/ethernet/mediatek/mtk_hnat/hnat_debugfs.c
+@@ -2469,7 +2469,7 @@ static const struct file_operations hnat_mape_toggle_fops = {
+ 
+ static int hnat_hook_toggle_read(struct seq_file *m, void *private)
+ {
+-	pr_info("value=%d, hook is %s now!\n", hook_toggle, (hook_toggle) ? "enabled" : "disabled");
++	seq_printf(m, "%s\n", (hook_toggle) ? "enabled" : "disabled");
+ 
+ 	return 0;
+ }
-- 

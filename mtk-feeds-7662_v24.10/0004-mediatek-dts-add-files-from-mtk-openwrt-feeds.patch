diff --git a/target/linux/mediatek/files-6.6/arch/arm64/boot/dts/mediatek/mt7988d-rfb-2pcie.dtso b/target/linux/mediatek/files-6.6/arch/arm64/boot/dts/mediatek/mt7988d-rfb-2pcie.dtso

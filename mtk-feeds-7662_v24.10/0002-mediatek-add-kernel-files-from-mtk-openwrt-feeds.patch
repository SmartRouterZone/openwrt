+		reg_val |= FIELD_PREP(MTK_LRO_DATA_VLD, y);				\
+		mtk_w32(eth, reg_val, MTK_GLO_MEM_DATA(1));				\
+		reg_val = FIELD_PREP(MTK_GLO_MEM_IDX, MTK_LRO_MEM_IDX);			\

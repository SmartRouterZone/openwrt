+#define AN8855_PORT_MIB_RXB_ID	40	/* RxByte */
+
+#define MIB_DESC(_s, _o, _n)   \
+	{						\
+		.size = (_s),	\
+		.offset = (_o), \
+		.name = (_n),	\

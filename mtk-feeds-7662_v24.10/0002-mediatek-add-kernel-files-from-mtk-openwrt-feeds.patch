+static const struct file_operations mtk_eth_debugfs_qdma_sched_fops = {
+	.owner = THIS_MODULE,
+	.open = simple_open,
+	.read = mtk_qdma_sched_read,
+	.write = mtk_qdma_sched_write,
+	.llseek = default_llseek,
+};

+		}
+		return -1;
+	}
+
+	/* Fill Layer2 Info.*/
+	entry = ppe_fill_L2_info(entry, hw_path);
+
+	if ((skb_hnat_tops(skb) && hw_path->flags & BIT(DEV_PATH_TNL)) ||
+	    (!skb_hnat_cdrt(skb) && skb_hnat_is_encrypt(skb) &&

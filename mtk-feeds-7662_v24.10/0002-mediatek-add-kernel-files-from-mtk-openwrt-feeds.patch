+static const struct file_operations mtk_eth_debugfs_hwlro_auto_tlb_fops = {
+	.owner = THIS_MODULE,
+	.open = mtk_hwlro_auto_tlb_open,
+	.read = seq_read,
+	.llseek = seq_lseek,
+	.write = mtk_hwlro_auto_tlb_write,
+	.release = single_release
+};

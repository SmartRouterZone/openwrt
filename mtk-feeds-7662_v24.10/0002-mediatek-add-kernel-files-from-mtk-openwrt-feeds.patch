+
+		default:
+			return -1;
+		}
+		if (debug_level >= 7)
+			trace_printk(
+				"[%s]skb->head=%p, skb->data=%p,ipv6_hdr=%p, skb->len=%d, skb->data_len=%d\n",
+				__func__, skb->head, skb->data, ip6h, skb->len,
+				skb->data_len);
+		break;
+
+	default:
+		if (IS_L2_BRIDGE(&entry)) {

+static inline int an8855_swconfig_init(struct gsw_an8855 *gsw)
+{
+	an8855_apply_vlan_config(gsw);
+
+	return 0;
+}
+
+static inline void an8855_swconfig_destroy(struct gsw_an8855 *gsw)
+{
+}
+#endif
+
+#endif /* _AN8855_SWCONFIG_H_ */

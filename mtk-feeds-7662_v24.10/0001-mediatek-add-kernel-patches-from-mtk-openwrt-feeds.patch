+ static const struct flash_info *spi_nor_get_flash_info(struct spi_nor *nor,
+@@ -3482,6 +3496,15 @@ static int spi_nor_hw_reset(struct spi_n
+ 	return 0;
+ }
+ 
++static void spi_nor_reset_read(struct spi_nor *nor)

+ 
+ 		crc = onfi_crc16(ONFI_CRC_BASE, (u8 *)pbuf, 254);
+--- /dev/null
++++ b/drivers/mtd/nand/param.c
+@@ -0,0 +1,52 @@
++/* SPDX-License-Identifier: GPL-2.0 */

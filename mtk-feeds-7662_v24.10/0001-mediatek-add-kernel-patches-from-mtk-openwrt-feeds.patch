diff --git a/target/linux/mediatek/patches-6.6/999-spi-nand-01-integrate-ONFI-and-CASN-manipulation.patch b/target/linux/mediatek/patches-6.6/999-spi-nand-01-integrate-ONFI-and-CASN-manipulation.patch

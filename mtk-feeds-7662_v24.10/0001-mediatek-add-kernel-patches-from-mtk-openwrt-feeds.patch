++	pr_notice("\nUsage:\n"
++		  "[debugfs] = /sys/kernel/debug/mdio-bus\':[phy_addr]\n"
++		  "echo [mode] [para] > /[debugfs]/port_mode\n"
++		  "echo re-an > /[debugfs]/port_mode\n"
++		  "echo auto > /[debugfs]/port_mode\n"
++		  "echo 2500 > /[debugfs]/port_mode\n"
++		  "echo 1000 > /[debugfs]/port_mode\n"

diff --git a/target/linux/mediatek/patches-6.6/999-1714-v6.13-net-phy-2p5g-eee-backport-net-phy-c45-don-t-use-temporary-linkmo.patch b/target/linux/mediatek/patches-6.6/999-1714-v6.13-net-phy-2p5g-eee-backport-net-phy-c45-don-t-use-temporary-linkmo.patch

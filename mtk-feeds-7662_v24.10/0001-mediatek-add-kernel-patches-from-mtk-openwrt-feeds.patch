+ 
+-	if (cnt_duty) {
+-		pwm_mediatek_writel(pc, pwm->hwpwm, reg_thres, cnt_duty - 1);
+-		pwm_mediatek_enable(chip, pwm);
+-	} else {
+-		pwm_mediatek_disable(chip, pwm);

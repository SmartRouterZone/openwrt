+ 	.ndo_change_mtu		= dsa_slave_change_mtu,
++#if IS_ENABLED(CONFIG_NF_FLOW_TABLE)
++	.ndo_flow_offload_check	 = dsa_flow_offload_check,
++#endif
+ 	.ndo_fill_forward_path	= dsa_slave_fill_forward_path,
+ };
+ 
+-- 
+2.18.0

++
++static inline void eee_to_eeecfg(struct eee_config *eeecfg,
++				 const struct ethtool_keee *eee)
++{
++	eeecfg->tx_lpi_timer = eee->tx_lpi_timer;
++	eeecfg->tx_lpi_enabled = eee->tx_lpi_enabled;
++	eeecfg->eee_enabled = eee->eee_enabled;

+From 05b42ad94d564aa4b08960a7797ee530bb3b5555 Mon Sep 17 00:00:00 2001
+From: Bo-Cun Chen <bc-bocun.chen@mediatek.com>
+Date: Tue, 29 Oct 2024 14:26:04 +0800
+Subject: [PATCH] net: ethernet: mtk_eth_soc: remove pextp reset
+
+---
+ drivers/net/ethernet/mediatek/mtk_eth_soc.c | 37 ---------------------
+ drivers/net/ethernet/mediatek/mtk_eth_soc.h |  1 -
+ 2 files changed, 38 deletions(-)
+
+diff --git a/drivers/net/ethernet/mediatek/mtk_eth_soc.c b/drivers/net/ethernet/mediatek/mtk_eth_soc.c
+index 0da39e7..7237b9b 100644
+--- a/drivers/net/ethernet/mediatek/mtk_eth_soc.c
++++ b/drivers/net/ethernet/mediatek/mtk_eth_soc.c
+@@ -759,18 +759,6 @@ static void mtk_mac_config(struct phylink_config *config, unsigned int mode,
+ 		mac->id, phy_modes(state->interface), err);
+ }
+ 
+-static int mtk_mac_prepare(struct phylink_config *config, unsigned int mode,
+-			   phy_interface_t interface)
+-{
+-	struct mtk_mac *mac = container_of(config, struct mtk_mac,
+-					   phylink_config);
+-
+-	if (mac->pextp && mac->interface != interface)
+-		phy_reset(mac->pextp);
+-
+-	return 0;
+-}
+-
+ static int mtk_mac_finish(struct phylink_config *config, unsigned int mode,
+ 			  phy_interface_t interface)
+ {
+@@ -779,10 +767,6 @@ static int mtk_mac_finish(struct phylink_config *config, unsigned int mode,
+ 	struct mtk_eth *eth = mac->hw;
+ 	u32 mcr_cur, mcr_new;
+ 
+-	/* Setup PMA/PMD */
+-	if (mac->pextp)
+-		phy_set_mode_ext(mac->pextp, PHY_MODE_ETHERNET, interface);
+-
+ 	/* Enable SGMII */
+ 	if (interface == PHY_INTERFACE_MODE_SGMII ||
+ 	    phy_interface_mode_is_8023z(interface))
+@@ -972,15 +956,11 @@ static void mtk_mac_link_up(struct phylink_config *config,
+ 		mtk_gdm_mac_link_up(mac, phy, mode, interface, speed, duplex,
+ 				    tx_pause, rx_pause);
+ 
+-	/* Repeat pextp setup to tune link */
+-	if (mac->pextp)
+-		phy_set_mode_ext(mac->pextp, PHY_MODE_ETHERNET, interface);
+ }
+ 
+ static const struct phylink_mac_ops mtk_phylink_ops = {
+ 	.mac_select_pcs = mtk_mac_select_pcs,
+ 	.mac_config = mtk_mac_config,
+-	.mac_prepare = mtk_mac_prepare,
+ 	.mac_finish = mtk_mac_finish,
+ 	.mac_link_down = mtk_mac_link_down,
+ 	.mac_link_up = mtk_mac_link_up,
+@@ -3580,9 +3560,6 @@ static int mtk_open(struct net_device *dev)
+ 
+ 	ppe_num = eth->soc->ppe_num;
+ 
+-	if (mac->pextp)
+-		phy_power_on(mac->pextp);
+-
+ 	err = phylink_of_phy_connect(mac->phylink, mac->of_node, 0);
+ 	if (err) {
+ 		netdev_err(dev, "%s: could not attach PHY: %d\n", __func__,
+@@ -3733,9 +3710,6 @@ static int mtk_stop(struct net_device *dev)
+ 	for (i = 0; i < ARRAY_SIZE(eth->ppe); i++)
+ 		mtk_ppe_stop(eth->ppe[i]);
+ 
+-	if (mac->pextp)
+-		phy_power_off(mac->pextp);
+-
+ 	return 0;
+ }
+ 
+@@ -4819,17 +4793,6 @@ static int mtk_add_mac(struct mtk_eth *eth, struct device_node *np)
+ 		}
+ 	}
+ 
+-	if (mtk_is_netsys_v3_or_greater(eth) && (mac->sgmii_pcs || mac->usxgmii_pcs)) {
+-		mac->pextp = devm_of_phy_get(eth->dev, mac->of_node, NULL);
+-		if (IS_ERR(mac->pextp)) {
+-			if (PTR_ERR(mac->pextp) != -EPROBE_DEFER)
+-				dev_err(eth->dev, "cannot get PHY, error %ld\n",
+-					PTR_ERR(mac->pextp));
+-
+-			return PTR_ERR(mac->pextp);
+-		}
+-	}
+-
+ 	memset(mac->hwlro_ip, 0, sizeof(mac->hwlro_ip));
+ 	mac->hwlro_ip_cnt = 0;
+ 
+diff --git a/drivers/net/ethernet/mediatek/mtk_eth_soc.h b/drivers/net/ethernet/mediatek/mtk_eth_soc.h
+index a75d439..82e758e 100644
+--- a/drivers/net/ethernet/mediatek/mtk_eth_soc.h
++++ b/drivers/net/ethernet/mediatek/mtk_eth_soc.h
+@@ -1430,7 +1430,6 @@ struct mtk_mac {
+ 	struct phylink_config		phylink_config;
+ 	struct phylink_pcs		*sgmii_pcs;
+ 	struct phylink_pcs		*usxgmii_pcs;
+-	struct phy			*pextp;
+ 	struct mtk_eth			*hw;
+ 	struct mtk_hw_stats		*hw_stats;
+ 	__be32				hwlro_ip[MTK_MAX_LRO_IP_CNT];
+-- 
+2.45.2
+
diff --git a/target/linux/mediatek/patches-6.6/999-2702-crypto-avoid-rcu-stall.patch b/target/linux/mediatek/patches-6.6/999-2702-crypto-avoid-rcu-stall.patch
new file mode 100644
index 0000000000..203036cbf8
--- /dev/null
+++ b/target/linux/mediatek/patches-6.6/999-2702-crypto-avoid-rcu-stall.patch
@@ -0,0 +1,49 @@
+--- a/drivers/crypto/inside-secure/safexcel.c
++++ b/drivers/crypto/inside-secure/safexcel.c
+@@ -1038,7 +1038,6 @@ static inline void safexcel_handle_resul
+ 	int ret, i, nreq, ndesc, tot_descs, handled = 0;
+ 	bool should_complete;
+ 
+-handle_results:
+ 	tot_descs = 0;
+ 
+ 	nreq = readl(EIP197_HIA_RDR(priv, ring) + EIP197_HIA_xDR_PROC_COUNT);
+@@ -1047,6 +1046,7 @@ handle_results:
+ 	if (!nreq)
+ 		goto requests_left;
+ 
++	local_bh_disable();
+ 	for (i = 0; i < nreq; i++) {
+ 		req = safexcel_rdr_req_get(priv, ring);
+ 
+@@ -1059,15 +1059,13 @@ handle_results:
+ 			goto acknowledge;
+ 		}
+ 
+-		if (should_complete) {
+-			local_bh_disable();
++		if (should_complete)
+ 			crypto_request_complete(req, ret);
+-			local_bh_enable();
+-		}
+ 
+ 		tot_descs += ndesc;
+ 		handled++;
+ 	}
++	local_bh_enable();
+ 
+ acknowledge:
+ 	if (i)
+@@ -1075,12 +1073,6 @@ acknowledge:
+ 		       (tot_descs * priv->config.rd_offset),
+ 		       EIP197_HIA_RDR(priv, ring) + EIP197_HIA_xDR_PROC_COUNT);
+ 
+-	/* If the number of requests overflowed the counter, try to proceed more
+-	 * requests.
+-	 */
+-	if (nreq == EIP197_xDR_PROC_xD_PKT_MASK)
+-		goto handle_results;
+-
+ requests_left:
+ 	spin_lock_bh(&priv->ring[ring].lock);
+ 
diff --git a/target/linux/mediatek/patches-6.6/999-2702-net-ethernet-mtk_eth_soc-revise-xgmac-force-mode.patch b/target/linux/mediatek/patches-6.6/999-2702-net-ethernet-mtk_eth_soc-revise-xgmac-force-mode.patch
new file mode 100644
index 0000000000..be03359350
--- /dev/null
+++ b/target/linux/mediatek/patches-6.6/999-2702-net-ethernet-mtk_eth_soc-revise-xgmac-force-mode.patch
@@ -0,0 +1,98 @@
+From ac3df2b1a6c63e1c61df194d19cfd7493fbb4579 Mon Sep 17 00:00:00 2001
+From: Bo-Cun Chen <bc-bocun.chen@mediatek.com>
+Date: Fri, 1 Nov 2024 11:28:16 +0800
+Subject: [PATCH] net: ethernet: mtk_eth_soc: revise xgmac force mode
+
+---
+ drivers/net/ethernet/mediatek/mtk_eth_soc.c | 30 ++++++++++++++++-----
+ drivers/net/ethernet/mediatek/mtk_eth_soc.h |  3 ++-
+ 2 files changed, 25 insertions(+), 8 deletions(-)
+
+diff --git a/drivers/net/ethernet/mediatek/mtk_eth_soc.c b/drivers/net/ethernet/mediatek/mtk_eth_soc.c
+index 7237b9b..cc33931 100644
+--- a/drivers/net/ethernet/mediatek/mtk_eth_soc.c
++++ b/drivers/net/ethernet/mediatek/mtk_eth_soc.c
+@@ -759,6 +759,24 @@ static void mtk_mac_config(struct phylink_config *config, unsigned int mode,
+ 		mac->id, phy_modes(state->interface), err);
+ }
+ 
++static int mtk_mac_prepare(struct phylink_config *config, unsigned int mode,
++			   phy_interface_t iface)
++{
++	struct mtk_mac *mac = container_of(config, struct mtk_mac,
++					   phylink_config);
++
++	if (mtk_is_netsys_v3_or_greater(mac->hw) && mtk_interface_mode_is_xgmii(iface)) {
++		if (mac->id != MTK_GMAC1_ID)
++			mtk_m32(mac->hw, XMAC_MCR_TRX_DISABLE,
++				XMAC_MCR_TRX_DISABLE, MTK_XMAC_MCR(mac->id));
++
++		mtk_m32(mac->hw, MTK_XGMAC_FORCE_MODE(mac->id) | MTK_XGMAC_FORCE_LINK(mac->id),
++			MTK_XGMAC_FORCE_MODE(mac->id), MTK_XGMAC_STS(mac->id));
++	}
++
++	return 0;
++}
++
+ static int mtk_mac_finish(struct phylink_config *config, unsigned int mode,
+ 			  phy_interface_t interface)
+ {
+@@ -794,10 +812,9 @@ static void mtk_mac_link_down(struct phylink_config *config, unsigned int mode,
+ 
+ 	if (!mtk_interface_mode_is_xgmii(interface)) {
+ 		mtk_m32(mac->hw, MAC_MCR_TX_EN | MAC_MCR_RX_EN | MAC_MCR_FORCE_LINK, 0, MTK_MAC_MCR(mac->id));
+-		if (mtk_is_netsys_v3_or_greater(mac->hw))
+-			mtk_m32(mac->hw, MTK_XGMAC_FORCE_LINK(mac->id), 0, MTK_XGMAC_STS(mac->id));
+ 	} else if (mtk_is_netsys_v3_or_greater(mac->hw) && mac->id != MTK_GMAC1_ID) {
+ 		mtk_m32(mac->hw, XMAC_MCR_TRX_DISABLE, XMAC_MCR_TRX_DISABLE, MTK_XMAC_MCR(mac->id));
++		mtk_m32(mac->hw, MTK_XGMAC_FORCE_LINK(mac->id), 0, MTK_XGMAC_STS(mac->id));
+ 	}
+ }
+ 
+@@ -913,7 +930,7 @@ static void mtk_xgdm_mac_link_up(struct mtk_mac *mac,
+ 				 unsigned int mode, phy_interface_t interface,
+ 				 int speed, int duplex, bool tx_pause, bool rx_pause)
+ {
+-	u32 mcr, force_link = 0;
++	u32 mcr;
+ 
+ 	if (mac->id == MTK_GMAC1_ID)
+ 		return;
+@@ -923,10 +940,8 @@ static void mtk_xgdm_mac_link_up(struct mtk_mac *mac,
+ 	mdelay(20);
+ 	mtk_m32(mac->hw, XMAC_GLB_CNTCLR, XMAC_GLB_CNTCLR, MTK_XMAC_CNT_CTRL(mac->id));
+ 
+-	if (mac->interface == PHY_INTERFACE_MODE_INTERNAL || mac->id == MTK_GMAC3_ID)
+-		force_link = MTK_XGMAC_FORCE_LINK(mac->id);
+-
+-	mtk_m32(mac->hw, MTK_XGMAC_FORCE_LINK(mac->id), force_link, MTK_XGMAC_STS(mac->id));
++	mtk_m32(mac->hw, MTK_XGMAC_FORCE_LINK(mac->id),
++		MTK_XGMAC_FORCE_LINK(mac->id), MTK_XGMAC_STS(mac->id));
+ 
+ 	mcr = mtk_r32(mac->hw, MTK_XMAC_MCR(mac->id));
+ 	mcr &= ~(XMAC_MCR_FORCE_TX_FC | XMAC_MCR_FORCE_RX_FC | XMAC_MCR_TRX_DISABLE);
+@@ -961,6 +976,7 @@ static void mtk_mac_link_up(struct phylink_config *config,
+ static const struct phylink_mac_ops mtk_phylink_ops = {
+ 	.mac_select_pcs = mtk_mac_select_pcs,
+ 	.mac_config = mtk_mac_config,
++	.mac_prepare = mtk_mac_prepare,
+ 	.mac_finish = mtk_mac_finish,
+ 	.mac_link_down = mtk_mac_link_down,
+ 	.mac_link_up = mtk_mac_link_up,
+diff --git a/drivers/net/ethernet/mediatek/mtk_eth_soc.h b/drivers/net/ethernet/mediatek/mtk_eth_soc.h
+index 82e758e..bd4a62e 100644
+--- a/drivers/net/ethernet/mediatek/mtk_eth_soc.h
++++ b/drivers/net/ethernet/mediatek/mtk_eth_soc.h
+@@ -467,7 +467,8 @@
+ 
+ /* XMAC status registers */
+ #define MTK_XGMAC_STS(x)	(((x) == MTK_GMAC3_ID) ? 0x1001C : 0x1000C)
+-#define MTK_XGMAC_FORCE_LINK(x)	(((x) == MTK_GMAC2_ID) ? BIT(31) : BIT(15))
++#define MTK_XGMAC_FORCE_MODE(x)	(((x) == MTK_GMAC2_ID) ? BIT(31) : BIT(15))
++#define MTK_XGMAC_FORCE_LINK(x)	(((x) == MTK_GMAC2_ID) ? BIT(27) : BIT(11))
+ #define MTK_USXGMII_PCS_LINK	BIT(8)
+ #define MTK_XGMAC_RX_FC		BIT(5)
+ #define MTK_XGMAC_TX_FC		BIT(4)
+-- 
+2.45.2
+
diff --git a/target/linux/mediatek/patches-6.6/999-2704-net-ethernet-mtk_eth_soc-revise-mdc-divider-configur.patch b/target/linux/mediatek/patches-6.6/999-2704-net-ethernet-mtk_eth_soc-revise-mdc-divider-configur.patch
new file mode 100644
index 0000000000..074f02464b
--- /dev/null
+++ b/target/linux/mediatek/patches-6.6/999-2704-net-ethernet-mtk_eth_soc-revise-mdc-divider-configur.patch
@@ -0,0 +1,114 @@
+From 4a52cc4a27cfa1e648082f8abbbc8dfa75c44dc9 Mon Sep 17 00:00:00 2001
+From: Bo-Cun Chen <bc-bocun.chen@mediatek.com>
+Date: Fri, 24 Jan 2025 11:53:38 +0800
+Subject: [PATCH] net: ethernet: mtk_eth_soc: revise mdc divider configuration
+
+In the current method, the MDC divider was reset to the default setting
+of 2.5MHz after the NETSYS SER. Therefore, we need to move the MDC
+divider configuration function to mtk_hw_init().
+
+Signed-off-by: Bo-Cun Chen <bc-bocun.chen@mediatek.com>
+---
+ drivers/net/ethernet/mediatek/mtk_eth_soc.c | 62 ++++++++++++++-------
+ 1 file changed, 43 insertions(+), 19 deletions(-)

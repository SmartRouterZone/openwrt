+ 	default:
+ 		return -EINVAL;
+ 	}
+ 
+-	priv->fw_loaded = false;
++	priv->reg_base = devm_ioremap_resource(&phydev->mdio.dev, res);
++	if (IS_ERR(priv->reg_base)) {
++		dev_err(&phydev->mdio.dev, "Failed to map registers\n");
++		return PTR_ERR(priv->reg_base);

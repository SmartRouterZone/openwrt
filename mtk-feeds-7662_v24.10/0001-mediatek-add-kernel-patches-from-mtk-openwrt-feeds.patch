+  *
+--- a/include/linux/phy.h
++++ b/include/linux/phy.h
+@@ -30,6 +30,7 @@
+ #include <linux/refcount.h>
+ 
+ #include <linux/atomic.h>
++#include <net/eee.h>
+ 
+ #define PHY_DEFAULT_FEATURES	(SUPPORTED_Autoneg | \

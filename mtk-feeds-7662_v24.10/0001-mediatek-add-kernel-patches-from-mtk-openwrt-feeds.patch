+ 
+ /* USXGMII subsystem config registers */
+@@ -79,6 +80,7 @@ struct mtk_usxgmii_pcs {
+ 	void __iomem			*base;
+ 	struct clk			*clk;
+ 	struct reset_control		*reset;

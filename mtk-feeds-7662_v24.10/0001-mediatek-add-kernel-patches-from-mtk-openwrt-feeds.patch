++	step_col_12 = phy_read_mmd(phydev, 0x1e, 0x800c);
++	step_col_13 = phy_read_mmd(phydev, 0x1e, 0x800d);
++	phydev_dbg(phydev, "%s step_col_12 %d, step_col_13 %d\n",

+-#define MTK_PHY_PAGE_EXTENDED_1		0x0001
+-#define MTK_PHY_AUX_CTRL_AND_STATUS	0x14
+-#define   MTK_PHY_ENABLE_DOWNSHIFT	BIT(4)

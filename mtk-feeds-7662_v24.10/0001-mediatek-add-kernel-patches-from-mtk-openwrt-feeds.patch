diff --git a/target/linux/mediatek/patches-6.6/999-2714-net-ethernet-mtk_eth_soc-add-EEE-support-for-GMAC.patch b/target/linux/mediatek/patches-6.6/999-2714-net-ethernet-mtk_eth_soc-add-EEE-support-for-GMAC.patch
new file mode 100644
index 0000000000..a168f40f9b
--- /dev/null

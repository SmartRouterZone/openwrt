++		      MTK_GMAC2_2P5GPHY_V2 | MTK_GMAC2_SGMII | MTK_GMAC3_SGMII | \
++		      MTK_MUX_GMAC123_TO_GEPHY_SGMII | MTK_MUX_GMAC2_TO_2P5GPHY | \
++		      MTK_MUX_U3_GMAC23_TO_QPHY | MTK_U3_COPHY_V2 | \
++		      MTK_QDMA | MTK_PDMA_INT | MTK_RSS | \
++		      MTK_RSTCTRL_PPE1)
++
+ #define MT7988_CAPS  (MTK_36BIT_DMA | MTK_GDM1_ESW | MTK_GMAC1_SGMII | \
+ 		      MTK_GMAC2_2P5GPHY | MTK_GMAC2_SGMII | MTK_GMAC2_USXGMII | \
+ 		      MTK_GMAC3_SGMII | MTK_GMAC3_USXGMII | \
+-- 
+2.45.2
+
diff --git a/target/linux/mediatek/patches-6.6/999-2717-net-ethernet-mtk_eth_soc-convert-cap_bit-in-mtk_eth_.patch b/target/linux/mediatek/patches-6.6/999-2717-net-ethernet-mtk_eth_soc-convert-cap_bit-in-mtk_eth_.patch
new file mode 100644
index 0000000000..75265a88e3
--- /dev/null
+++ b/target/linux/mediatek/patches-6.6/999-2717-net-ethernet-mtk_eth_soc-convert-cap_bit-in-mtk_eth_.patch
@@ -0,0 +1,30 @@
+From ad478005e71cba56629b5b572f54f515f3d436ff Mon Sep 17 00:00:00 2001
+From: Bo-Cun Chen <bc-bocun.chen@mediatek.com>
+Date: Wed, 19 Mar 2025 17:21:16 +0800
+Subject: [PATCH] net: ethernet: mtk_eth_soc: convert cap_bit in mtk_eth_muxc
+ struct to u64
+
+Wihtout this patch, the mtk_eth_mux_setup() function may not correctly
+search the Mux.
+
+Signed-off-by: Bo-Cun Chen <bc-bocun.chen@mediatek.com>
+---
+ drivers/net/ethernet/mediatek/mtk_eth_path.c | 2 +-

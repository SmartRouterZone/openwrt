++} __packed;
++
++#endif /* __LINUX_MTD_CASN_H */
diff --git a/target/linux/mediatek/patches-6.6/999-spi-nor-01-fix-3B-4B-calibration.patch b/target/linux/mediatek/patches-6.6/999-spi-nor-01-fix-3B-4B-calibration.patch

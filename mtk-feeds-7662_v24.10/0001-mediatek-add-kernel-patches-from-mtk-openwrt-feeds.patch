+ {
+@@ -3518,8 +3541,16 @@ int spi_nor_scan(struct spi_nor *nor, co
+ 	if (ret)
+ 		return ret;
+ 
+-	if(nor->spimem)
+-		spi_mem_do_calibration(nor->spimem, spi_nor_cal_read, nor);
++	if(nor->spimem) {

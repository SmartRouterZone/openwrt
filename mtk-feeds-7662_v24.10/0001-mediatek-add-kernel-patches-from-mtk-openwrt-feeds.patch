+@@ -4919,6 +4925,7 @@ static bool mtk_hw_check_dma_hang(struct mtk_eth *eth)
+ 		    ((gdm_txfsm == eth->reset.gdm_txfsm[i]) && (gdm_txfsm == 0x1033))) {
+ 			if (++eth->reset.gdm_tx_hang_count[i] > 2) {

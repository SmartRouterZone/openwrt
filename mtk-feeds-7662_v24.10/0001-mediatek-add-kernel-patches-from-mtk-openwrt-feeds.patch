++static void airphy_cable_diag_help(void)
++{
++	pr_notice("\nUsage:\n"
++		  "[debugfs] = /sys/kernel/debug/mdio-bus\':[phy_addr]\n"
++		  "echo start > /[debugfs]/cable_diag\n");
++}

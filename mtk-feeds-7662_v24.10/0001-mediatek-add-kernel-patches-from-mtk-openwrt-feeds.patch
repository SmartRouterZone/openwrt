++static int air_get_autonego(struct phy_device *phydev, int *an)
++{
++	int reg;
++
++	reg = phy_read(phydev, MII_BMCR);
++	if (reg < 0)
++		return -EINVAL;
++	if (reg & BMCR_ANENABLE)
++		*an = AUTONEG_ENABLE;
++	else
++		*an = AUTONEG_DISABLE;
++	return 0;
++}

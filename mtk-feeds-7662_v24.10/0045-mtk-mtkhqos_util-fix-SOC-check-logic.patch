From ab05bc198b36a194954c8e58e9490199b501cbbf Mon Sep 17 00:00:00 2001
From: chasey-dev <ellenyoung0912@gmail.com>
Date: Wed, 26 Nov 2025 22:49:03 +0800
Subject: [PATCH 45/64] mtk: mtkhqos_util: fix SOC check logic - since DT path
 has been changed in kernel 6.6. without this, mtkhqos_util may not check
 mt7981 case properly

Signed-off-by: chasey-dev <ellenyoung0912@gmail.com>
---
 package/mtk/applications/mtkhqos_util/files/mtkhqos | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/package/mtk/applications/mtkhqos_util/files/mtkhqos b/package/mtk/applications/mtkhqos_util/files/mtkhqos
index 472c2954cc..01af812806 100644
--- a/package/mtk/applications/mtkhqos_util/files/mtkhqos
+++ b/package/mtk/applications/mtkhqos_util/files/mtkhqos
@@ -67,7 +67,7 @@ fi
 if [ "$hqos" -eq 0 ]; then
 	# disable hqos, enable hnat
 	dbg "disable hqos, enable hnat"
-	SOC=`cat /proc/device-tree/ethernet*/compatible | cut -c 10-15`
+	SOC=`cat /proc/device-tree/soc/ethernet*/compatible | cut -c 10-15`
 	DUAL_SCH=$(if [ $SOC = "mt7981" ]; then echo true; fi)
 
 	echo 0 $(sch_mode2str $sch0_mode) ${sch0_bw} > $hqos_path/qdma_sch0
-- 
2.50.1 (Apple Git-155)


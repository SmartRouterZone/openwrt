+AIR_ERROR_NO_T
+air_lpdet_getCtrl(
+    const UI32_T                    unit,
+    const UI32_T                    port,
+    const AIR_SWC_LPDET_CTRL_TYPE_T type,
+    BOOL_T                          *ptr_enable);
+
+/* FUNCTION NAME:   air_lpdet_clearStatus
+ * PURPOSE:

-@@ -123,6 +130,12 @@ gic: interrupt-controller@c000000 {
+@@ -123,6 +130,16 @@ gic: interrupt-controller@c000000 {
  			#interrupt-cells = <3>;
  		};
  
@@ -41,12 +41,16 @@ index 7aa42ce3d..5025a69e9 100644
 +			compatible = "mediatek,mt7986-consys";
 +			reg = <0 0x10000000 0 0x8600000>;
 +			memory-region = <&wmcpu_emi>;
++			/* This is synced from driver changes */
++			clocks = <&topckgen CLK_TOP_CONN_MCUSYS_SEL>, /* DIFFERENT from mt7981 */

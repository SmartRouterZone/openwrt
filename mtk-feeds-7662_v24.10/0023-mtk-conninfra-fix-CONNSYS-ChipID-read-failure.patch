-@@ -131,7 +144,8 @@ infracfg: infracfg@10001000 {
+@@ -131,7 +148,8 @@ infracfg: infracfg@10001000 {
  		};
  
  		wed_pcie: wed-pcie@10003000 {
@@ -56,7 +60,7 @@ index 7aa42ce3d..5025a69e9 100644
  				     "syscon";
  			reg = <0 0x10003000 0 0x10>;
  		};
-@@ -520,41 +534,39 @@ ethsysrst: reset-controller {
+@@ -520,41 +538,39 @@ ethsysrst: reset-controller {
  			};
          };
  
@@ -122,7 +126,7 @@ index 7aa42ce3d..5025a69e9 100644
  			clocks = <&ethsys CLK_ETH_FE_EN>,

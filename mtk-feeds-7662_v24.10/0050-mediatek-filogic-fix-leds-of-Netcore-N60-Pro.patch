From cb430fb8a45e7eebc21629f271590857359eb8c8 Mon Sep 17 00:00:00 2001
From: chasey-dev <ellenyoung0912@gmail.com>
Date: Thu, 27 Nov 2025 20:32:10 +0800
Subject: [PATCH 50/64] mediatek: filogic: fix leds of Netcore N60 Pro - adjust
 2.5G phy leds to DT defination - add usb port trigger kmod to default
 packages

Signed-off-by: chasey-dev <ellenyoung0912@gmail.com>
---
 .../mediatek/dts/mt7986a-netcore-n60-pro.dts  | 24 ++-----------------
 .../filogic/base-files/etc/board.d/01_leds    |  7 +++---
 target/linux/mediatek/image/filogic-ext.mk    |  2 +-
 target/linux/mediatek/image/filogic.mk        |  2 +-
 4 files changed, 8 insertions(+), 27 deletions(-)

diff --git a/target/linux/mediatek/dts/mt7986a-netcore-n60-pro.dts b/target/linux/mediatek/dts/mt7986a-netcore-n60-pro.dts
index 4272bac7a5..0c872651b2 100644
--- a/target/linux/mediatek/dts/mt7986a-netcore-n60-pro.dts
+++ b/target/linux/mediatek/dts/mt7986a-netcore-n60-pro.dts
@@ -146,33 +146,13 @@
 	phy5: phy@5 {
 		compatible = "ethernet-phy-ieee802.3-c45";
 		reg = <5>;
-
-		leds {
-			#address-cells = <1>;
-			#size-cells = <0>;
-
-			led@3 {
-				reg = <3>;
-				color = <LED_COLOR_ID_GREEN>;
-				function = LED_FUNCTION_LAN;
-			};
-		};
+		mxl,led-config = <0x0 0x0 0x0 0x3f0>;
 	};
 
 	phy6: phy@6 {
 		compatible = "ethernet-phy-ieee802.3-c45";
 		reg = <6>;
-
-		leds {
-			#address-cells = <1>;
-			#size-cells = <0>;
-
-			led@3 {
-				reg = <3>;
-				color = <LED_COLOR_ID_GREEN>;
-				function = LED_FUNCTION_WAN;
-			};
-		};
+		mxl,led-config = <0x0 0x0 0x0 0x3f0>;
 	};
 
 	switch: switch@1f {
diff --git a/target/linux/mediatek/filogic/base-files/etc/board.d/01_leds b/target/linux/mediatek/filogic/base-files/etc/board.d/01_leds
index e2b2b8eacd..522be38826 100644
--- a/target/linux/mediatek/filogic/base-files/etc/board.d/01_leds
+++ b/target/linux/mediatek/filogic/base-files/etc/board.d/01_leds
@@ -95,10 +95,11 @@ mercusys,mr90x-v1-ubi)
 	ucidef_set_led_netdev "lan-2" "lan-2" "green:lan-2" "lan2" "link tx rx"
 	ucidef_set_led_netdev "wan" "wan" "green:wan" "eth1" "link tx rx"
 	;;
-netcore,n60-pro)
-	ucidef_set_led_netdev "wanlink" "WANLINK" "mdio-bus:06:green:wan" "eth1" "link_10 link_100 link_1000 link_2500 tx rx"
-	ucidef_set_led_netdev "lan-1" "LAN-1" "mdio-bus:05:green:lan" "lan1" "link_10 link_100 link_1000 link_2500 tx rx"
+netcore,n60-pro|\
+netcore,n60-pro-mtkuboot)
+	ucidef_set_led_netdev "wlan5g" "WLAN_5G" "blue:wlan" "rax0" "link"
 	ucidef_set_led_netdev "wan" "WAN" "blue:wan" "eth1" "link"
+	ucidef_set_led_usbport "usb" "USB" "blue:usb" "usb2-port1"
 	;;
 netgear,wax220)
 	ucidef_set_led_netdev "eth0" "LAN" "green:lan" "eth0"
diff --git a/target/linux/mediatek/image/filogic-ext.mk b/target/linux/mediatek/image/filogic-ext.mk
index 8e5299f9e9..bad82c4c36 100644
--- a/target/linux/mediatek/image/filogic-ext.mk
+++ b/target/linux/mediatek/image/filogic-ext.mk
@@ -21,7 +21,7 @@ define Device/netcore_n60-pro-mtkuboot
   DEVICE_VARIANT := (MTK U-Boot layout)
   DEVICE_DTS := mt7986a-netcore-n60-pro-mtkuboot
   DEVICE_DTS_DIR := ../dts-ext
-  DEVICE_PACKAGES := kmod-usb3 automount
+  DEVICE_PACKAGES := kmod-usb3 automount kmod-usb-ledtrig-usbport 
   UBINIZE_OPTS := -E 5
   BLOCKSIZE := 128k
   PAGESIZE := 2048
diff --git a/target/linux/mediatek/image/filogic.mk b/target/linux/mediatek/image/filogic.mk
index 58eda1e445..194d7bed1b 100644
--- a/target/linux/mediatek/image/filogic.mk
+++ b/target/linux/mediatek/image/filogic.mk
@@ -1662,7 +1662,7 @@ define Device/netcore_n60-pro
         fit lzma $$(KDIR)/image-$$(firstword $$(DEVICE_DTS)).dtb with-initrd | pad-to 64k
   IMAGE/sysupgrade.itb := append-kernel | \
         fit gzip $$(KDIR)/image-$$(firstword $$(DEVICE_DTS)).dtb external-static-with-rootfs | append-metadata
-  DEVICE_PACKAGES := kmod-mt7915e kmod-mt7986-firmware mt7986-wo-firmware kmod-usb3 automount
+  DEVICE_PACKAGES := kmod-mt7915e kmod-mt7986-firmware mt7986-wo-firmware kmod-usb3 automount kmod-usb-ledtrig-usbport
   ARTIFACTS := preloader.bin bl31-uboot.fip
   ARTIFACT/preloader.bin := mt7986-bl2 spim-nand-ddr4
   ARTIFACT/bl31-uboot.fip := mt7986-bl31-uboot netcore_n60-pro
-- 
2.50.1 (Apple Git-155)


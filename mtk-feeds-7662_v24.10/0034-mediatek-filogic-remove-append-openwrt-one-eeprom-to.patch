From 4be1c85cbef1f11c3e2b923f6253b36e6b46aa42 Mon Sep 17 00:00:00 2001
From: chasey-dev <ellenyoung0912@gmail.com>
Date: Sat, 22 Nov 2025 23:26:09 +0800
Subject: [PATCH 34/64] mediatek: filogic: remove append-openwrt-one-eeprom to
 avoid build issues - since we have removed mt76, this change is to pass
 coverage build tests - this is a untested change on certain device

Signed-off-by: chasey-dev <ellenyoung0912@gmail.com>
---
 target/linux/mediatek/image/filogic.mk | 5 -----
 1 file changed, 5 deletions(-)

diff --git a/target/linux/mediatek/image/filogic.mk b/target/linux/mediatek/image/filogic.mk
index 920381e15c..58eda1e445 100644
--- a/target/linux/mediatek/image/filogic.mk
+++ b/target/linux/mediatek/image/filogic.mk
@@ -83,10 +83,6 @@ define Build/append-gl-metadata
 	}
 endef
 
-define Build/append-openwrt-one-eeprom
-	dd if=$(STAGING_DIR_IMAGE)/mt7981_eeprom_mt7976_dbdc.bin >> $@
-endef
-
 define Build/zyxel-nwa-fit-filogic
 	$(TOPDIR)/scripts/mkits-zyxel-fit-filogic.sh \
 		$@.its $@ "80 e1 ff ff ff ff ff ff ff ff"
@@ -1806,7 +1802,6 @@ define Device/openwrt_one
 					   mt7981-bl2 spim-nand-ubi-ddr4 | pad-to 1024k | \
 					   ubinize-image fit squashfs-sysupgrade.itb
   ARTIFACT/nor-factory.bin		:= mt7981-bl2 nor-ddr4 | pad-to 256k | \
-					   append-openwrt-one-eeprom | pad-to 1024k | \
 					   mt7981-bl31-uboot openwrt_one-nor | pad-to 512k | \
 					   append-image-stage initramfs.itb
   UBINIZE_OPTS := -E 5
-- 
